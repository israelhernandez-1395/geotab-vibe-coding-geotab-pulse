  "files": {
    "pulse.html": "<!DOCTYPE html><html><head><meta charset='utf-8'><title>Geotab Pulse</title></head><body style='margin:0;padding:20px;font-family:Segoe UI,sans-serif;background:#1a1a1a;color:#eee;'><div style='display:flex;gap:20px;margin-bottom:20px;'><div style='flex:1;background:#252525;padding:20px;border-radius:8px;border-left:4px solid #3498db;'><div style='font-size:12px;color:#888;'>Unidades en Zona</div><div id='kpi-stopped' style='font-size:32px;font-weight:bold;'>0</div></div><div style='flex:1;background:#252525;padding:20px;border-radius:8px;border-left:4px solid #e74c3c;'><div style='font-size:12px;color:#888;'>Retrasos Críticos</div><div id='kpi-critical' style='font-size:32px;font-weight:bold;'>0</div></div><div style='flex:1;background:#252525;padding:20px;border-radius:8px;'><div style='font-size:12px;color:#888;'>Umbral: <span id='threshold-val'>60</span> min</div><input type='range' id='threshold-slider' min='15' max='240' value='60' style='width:100%;margin-top:10px;'></div><div style='flex:0.5;display:flex;align-items:center;'><button onclick='exportToCSV()' style='background:#27ae60;color:white;border:none;padding:10px 20px;border-radius:4px;cursor:pointer;width:100%;font-weight:bold;'>Descargar CSV</button></div></div><div style='background:#252525;border-radius:8px;overflow:hidden;'><table style='width:100%;border-collapse:collapse;' id='main-table'><thead style='background:#333;color:#aaa;font-size:12px;text-transform:uppercase;'><tr><th style='padding:12px;text-align:left;'>Vehículo</th><th style='padding:12px;text-align:left;'>Conductor</th><th style='padding:12px;text-align:left;'>Zona</th><th style='padding:12px;text-align:left;'>Estancia</th><th style='padding:12px;text-align:left;'>Acción</th></tr></thead><tbody id='table-body'></tbody></table><div id='loading-state' style='padding:40px;text-align:center;color:#3498db;'>Sincronizando...</div></div><div id='esc-modal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:1000;align-items:center;justify-content:center;'><div style='background:#2c3e50;padding:30px;border-radius:10px;width:400px;box-shadow:0 0 20px rgba(0,0,0,0.5);'><h3 style='margin-top:0;'>Escalar Retraso</h3><p id='modal-info' style='font-size:14px;color:#bdc3c7;'></p><label style='font-size:12px;display:block;margin-bottom:5px;'>Correo Supervisor (Opcional):</label><input type='email' id='sup-email' placeholder='supervisor@empresa.com' style='width:100%;padding:8px;margin-bottom:15px;background:#34495e;border:1px solid #555;color:white;border-radius:4px;'><button id='btn-send-esc' style='background:#3498db;color:white;border:none;padding:10px;width:100%;border-radius:4px;cursor:pointer;font-weight:bold;'>Abrir Correo de Escalamiento</button><button onclick='document.getElementById(\"esc-modal\").style.display=\"none\"' style='background:transparent;color:#95a5a6;border:none;padding:10px;width:100%;cursor:pointer;font-size:12px;margin-top:5px;'>Cancelar</button></div></div><div id='debug-toggle' style='position:fixed;bottom:0;left:0;right:0;text-align:center;'><button onclick='var d=document.getElementById(\"debug-log\");d.style.display=d.style.display===\"none\"?\"block\":\"none\";' style='background:#e74c3c;color:#fff;border:none;padding:4px 16px;cursor:pointer;font-size:12px;border-radius:4px 4px 0 0;'>Debug</button><button onclick='copyDebugData()' style='background:#f39c12;color:#fff;border:none;padding:4px 16px;cursor:pointer;font-size:12px;border-radius:4px 4px 0 0;margin-left:4px;'>Copy Data</button><pre id='debug-log' style='display:none;background:#1e1e1e;color:#0f0;padding:10px;max-height:200px;overflow-y:auto;text-align:left;font-size:11px;'></pre></div><script>var _debugData={};var currentThreshold=60;var _stancias={};var _currentData=[];function isPointInPoly(pt,poly){for(var c=false,i=-1,l=poly.length,j=l-1;++i<l;j=i)((poly[i].y<=pt.y&&pt.y<poly[j].y)||(poly[j].y<=pt.y&&pt.y<poly[i].y))&&(pt.x<(poly[j].x-poly[i].x)*(pt.y-poly[i].y)/(poly[j].y-poly[i].y)+poly[i].x)&&(c=!c);return c;}function exportToCSV(){var csv=['Vehiculo,Conductor,Zona,Estancia(min)'];_currentData.forEach(function(r){csv.push(r.v+','+r.c+','+r.z+','+r.t);});var blob=new Blob([csv.join('\\n')],{type:'text/csv'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='Reporte_Pulse.csv';a.click();}function openEscalate(vName,drvName,drvEmail,zName,time){var modal=document.getElementById('esc-modal');var info=document.getElementById('modal-info');info.textContent='Vehículo: '+vName+' | Zona: '+zName+' ('+time+' min)';modal.style.display='flex';document.getElementById('btn-send-esc').onclick=function(){var sup=document.getElementById('sup-email').value;var cc=sup?('&cc='+sup):'';var body='Se informa que la unidad '+vName+' conducida por '+drvName+' lleva '+time+' minutos en la zona '+zName+'.';var mailto='mailto:'+drvEmail+'?subject=Escalamiento de Retraso: '+vName+cc+'&body='+encodeURIComponent(body);window.location.href=mailto;modal.style.display='none';};}geotab.addin['geotab-pulse']=function(){var apiObj,refreshInterval,zonesCache=[];function renderUI(devices,statuses,drivers){var devMap={};devices.forEach(function(d){devMap[d.id]=d;});var drvMap={};drivers.forEach(function(u){drvMap[u.id]=u;});var now=new Date();var rowsHtml='';var stoppedCount=0,criticalCount=0;_currentData=[];statuses.forEach(function(s){var inZone=null;for(var i=0;i<zonesCache.length;i++){var z=zonesCache[i];if(z.points&&isPointInPoly({x:s.longitude,y:s.latitude},z.points)){inZone=z;break;}}if(inZone){if(!_stancias[s.device.id]||_stancias[s.device.id].zoneId!==inZone.id){_stancias[s.device.id]={zoneId:inZone.id,entry:new Date().toISOString()};}var diffMin=Math.floor((now-new Date(_stancias[s.device.id].entry))/60000);if(diffMin>=currentThreshold){stoppedCount++;var isCrit=diffMin>=(currentThreshold*1.5);if(isCrit)criticalCount++;var dev=devMap[s.device.id]||{name:s.device.id,id:s.device.id};var drv=s.driver?drvMap[s.driver.id]:null;var drvName=drv?(drv.firstName+' '+drv.lastName):'No asignado';var drvEmail=drv?drv.name:'';_currentData.push({v:dev.name,c:drvName,z:inZone.name,t:diffMin});rowsHtml+='<tr style=\"border-bottom:1px solid #333;\"><td style=\"padding:12px;\"><a href=\"#\" style=\"color:#3498db;text-decoration:none;\" onclick=\"event.preventDefault();window.parent.location.hash=\\'device,id:'+dev.id+'\\'\">'+dev.name+'</a></td><td style=\"padding:12px;\">'+drvName+'</td><td style=\"padding:12px;\">'+inZone.name+'</td><td style=\"padding:12px;'+(isCrit?'color:#ff4d4d;font-weight:bold;':'color:#f39c12;')+'\">'+diffMin+' min</td><td style=\"padding:12px;\"><button onclick=\"openEscalate(\\''+dev.name+'\\',\\''+drvName+'\\',\\''+drvEmail+'\\',\\''+inZone.name+'\\','+diffMin+')\" style=\"background:#3498db;color:white;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;\">Escalar</button></td></tr>';}}else{delete _stancias[s.device.id];}});document.getElementById('table-body').innerHTML=rowsHtml;document.getElementById('kpi-stopped').textContent=stoppedCount;document.getElementById('kpi-critical').textContent=criticalCount;document.getElementById('loading-state').style.display=(stoppedCount===0?'block':'none');}function refreshData(){if(!apiObj)return;apiObj.multiCall([[\"Get\",{typeName:\"Device\"}],[\"Get\",{typeName:\"DeviceStatusInfo\"}],[\"Get\",{typeName:\"User\",search:{isDriver:true}}]],function(results){document.getElementById('loading-state').style.display='none';renderUI(results[0],results[1],results[2]);},function(err){});}return{initialize:function(api,state,callback){apiObj=api;document.getElementById('threshold-slider').oninput=function(){currentThreshold=parseInt(this.value);document.getElementById('threshold-val').textContent=this.value;refreshData();};api.call(\"Get\",{typeName:\"Zone\"},function(zones){zonesCache=zones;refreshData();refreshInterval=setInterval(refreshData,30000);},function(err){});callback();},focus:function(){refreshData();},blur:function(){if(refreshInterval)clearInterval(refreshInterval);}};};</script></body></html>"
  }
}
